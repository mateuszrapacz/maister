{
  "name": "maister",
  "description": "Maister workflow orchestrator — invokes /maister-* skills and delegates to maister-* subagents",
  "tools": [
    "*"
  ],
  "allowedTools": [
    "*"
  ],
  "includeMcpJson": true,
  "toolsSettings": {
    "subagent": {
      "availableAgents": [
        "maister-*"
      ],
      "trustedAgents": [
        "maister-*"
      ]
    }
  },
  "prompt": "file://./instructions/maister.md",
  "hooks": {
    "preToolUse": [
      {
        "matcher": "shell",
        "command": "~/.kiro-maister/hooks/block-destructive-commands-kiro.sh",
        "timeout_ms": 5000
      },
      {
        "matcher": "shell",
        "command": "~/.kiro-maister/hooks/rtk-rewrite.sh",
        "timeout_ms": 5000
      },
      {
        "matcher": "subagent",
        "command": "~/.kiro-maister/hooks/subagent-spawn-tracker.sh",
        "timeout_ms": 5000
      }
    ],
    "postToolUse": [
      {
        "matcher": "subagent",
        "command": "~/.kiro-maister/hooks/subagent-complete-cleanup.sh",
        "timeout_ms": 5000
      }
    ],
    "agentSpawn": [
      {
        "command": "~/.kiro-maister/hooks/skill-invocation-reminder.sh",
        "timeout_ms": 10000
      }
    ],
    "userPromptSubmit": [
      {
        "command": "~/.kiro-maister/hooks/skill-invocation-reminder.sh",
        "timeout_ms": 10000
      }
    ],
    "stop": [
      {
        "command": "~/.kiro-maister/hooks/stop-state-reminder-kiro.sh",
        "timeout_ms": 10000
      }
    ]
  }
}
