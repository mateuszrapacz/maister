    "skill://.kiro/skills/maister-performance/SKILL.md",
    "skill://.kiro/skills/maister-product-design/SKILL.md",
    "skill://.kiro/skills/maister-quick-bugfix/SKILL.md",
    "skill://.kiro/skills/maister-quick-dev/SKILL.md",
