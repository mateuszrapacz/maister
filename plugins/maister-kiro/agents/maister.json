    "skill://.kiro/skills/maister-reviews-spec-audit/SKILL.md",
    "skill://.kiro/skills/maister-standards-discover/SKILL.md",
    "skill://.kiro/skills/maister-standards-update/SKILL.md",
    "skill://.kiro/skills/maister-thermo-nuclear-code-quality-review/SKILL.md",
    "skill://.kiro/skills/maister-thermo-nuclear-review/SKILL.md",
    "skill://.kiro/skills/maister-thermos/SKILL.md",
    "skill://.kiro/skills/maister-work/SKILL.md"
  ],
  "toolsSettings": {
    "subagent": {
      "trustedAgents": [
        "maister-*"
      ]
    }
  },
  "promptFile": "instructions/maister.md",
  "hooks": {
    "preToolUse": [
      {
        "matcher": "shell",
        "command": "../hooks/block-destructive-commands-kiro.sh",
        "timeout": 5
      },
      {
        "matcher": "subagent",
        "command": "../hooks/subagent-spawn-tracker.sh",
        "timeout": 5
      }
    ],
    "postToolUse": [
      {
        "matcher": "subagent",
        "command": "../hooks/subagent-complete-cleanup.sh",
        "timeout": 5
      }
    ],
    "agentSpawn": [
      {
        "command": "../hooks/skill-invocation-reminder.sh",
        "timeout": 10
      }
    ],
    "userPromptSubmit": [
      {
        "command": "../hooks/skill-invocation-reminder.sh",
        "timeout": 10
      }
    ]
  }
}
