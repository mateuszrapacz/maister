{
  "version": 1,
  "hooks": {
    "subagentStart": [
      {
        "command": "${CURSOR_PLUGIN_ROOT}/hooks/maister-subagent-start-tracker.sh",
        "timeout": 5
      },
      {
        "command": "${CURSOR_PLUGIN_ROOT}/hooks/maister-block-risky-subagents.sh",
        "timeout": 5
      }
    ],
    "subagentStop": [
      {
        "command": "${CURSOR_PLUGIN_ROOT}/hooks/maister-subagent-stop-cleanup.sh",
        "timeout": 5
      }
    ],
    "preToolUse": [
      {
        "command": "${CURSOR_PLUGIN_ROOT}/hooks/maister-block-destructive-commands.sh",
        "matcher": "Shell",
        "timeout": 5
      }
    ],
    "beforeShellExecution": [
      {
        "command": "${CURSOR_PLUGIN_ROOT}/hooks/maister-block-destructive-commands.sh",
        "timeout": 5
      }
    ],
    "preCompact": [
      {
        "command": "${CURSOR_PLUGIN_ROOT}/hooks/maister-post-compact-reminder.sh",
        "timeout": 10
      }
    ],
    "sessionStart": [
      {
        "command": "${CURSOR_PLUGIN_ROOT}/hooks/maister-skill-invocation-reminder.sh",
        "timeout": 10
      }
    ],
    "stop": [
      {
        "command": "${CURSOR_PLUGIN_ROOT}/hooks/maister-stop-state-reminder.sh",
        "timeout": 10
      }
    ],
    "sessionEnd": [
      {
        "command": "${CURSOR_PLUGIN_ROOT}/hooks/maister-session-end-hook-state-cleanup.sh",
        "timeout": 5
      }
    ]
  }
}
