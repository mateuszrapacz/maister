    {
      "id": "cursor-skill-name-v1",
      "rationale": "Cursor slash skills use maister-* names instead of Claude-style maister:* names."
    },
    {
      "id": "cursor-question-tool-v1",
      "rationale": "Cursor exposes AskQuestion rather than AskUserQuestion."
    },
    {
      "id": "cursor-framework-path-v1",
      "rationale": "The Cursor package materializes the orchestrator framework below lib/."
    },
    {
      "id": "cursor-skill-references-v1",
      "rationale": "References must use Cursor's maister-* public skill names."
    },
    {
      "id": "cursor-todowrite-v1",
      "rationale": "Cursor workflow state uses TodoWrite rather than Claude task tools."
    },
    {
      "id": "cursor-host-neutralization-v1",
      "rationale": "Known legacy-host references in validated Cursor assets are neutralized at narrowly scoped init, migration-reference, and standards-reference seams."
    }
