{
  "version": 1,
  "hooks": {
    "subagentStart": [
      {
        "command": "${CURSOR_PLUGIN_ROOT}/hooks/subagent-start-tracker.sh",
        "timeout": 5
      }
    ],
    "subagentStop": [
      {
        "command": "${CURSOR_PLUGIN_ROOT}/hooks/subagent-stop-cleanup.sh",
        "timeout": 5
      }
    ],
    "beforeShellExecution": [
      {
        "command": "${CURSOR_PLUGIN_ROOT}/hooks/block-destructive-commands.sh",
        "timeout": 5
      }
    ],
    "preCompact": [
      {
        "command": "${CURSOR_PLUGIN_ROOT}/hooks/post-compact-reminder.sh",
        "timeout": 10
      }
    ],
    "sessionStart": [
      {
        "command": "${CURSOR_PLUGIN_ROOT}/hooks/skill-invocation-reminder.sh",
        "timeout": 10
      }
    ]
  }
}
